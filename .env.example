# ─────────────────────────────────────────────
#  Telegram LinkedIn X-ray Bot — Environment
# ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# SerpAPI Key (https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# ── Optional tuning ──────────────────────────

# Max results returned per search (1-20)
MAX_RESULTS=15

# How many Google pages to fetch per query (1-3)
SEARCH_PAGES=2

# Seconds to wait between API calls (rate-limit safety)
REQUEST_DELAY=1.0

# CSV export directory (relative to project root)
DATA_DIR=data

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
